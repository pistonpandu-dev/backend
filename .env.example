# App
APP_NAME=Rayan Admin Backend
NODE_ENV=production
PORT=3000
BASE_URL=https://api.domainanda.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rayan_admin
DIRECT_URL=postgresql://user:password@localhost:5432/rayan_admin

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-key
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@domainanda.com

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# Upload
UPLOAD_DRIVER=local
UPLOAD_PATH=uploads

# CORS
CORS_ORIGIN=*

# Rate Limit
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Socket
SOCKET_CORS=*

# Encryption
ENCRYPTION_SECRET=your-encryption-secret-key

# Security
SSL_ENABLED=true
