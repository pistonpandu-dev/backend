# Application
APP_NAME=Rayan Admin Backend
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://rayan:password@localhost:5432/rayan_admin
DIRECT_URL=postgresql://rayan:password@localhost:5432/rayan_admin

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters
JWT_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@domainanda.com

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBgkqhkiG9w0BAQEFAASCBKYwggSiAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Upload
UPLOAD_DRIVER=local
UPLOAD_PATH=uploads

# CORS
CORS_ORIGIN=http://localhost:3001,https://admin.domainanda.com

# Rate Limit
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Socket
SOCKET_CORS=http://localhost:3001

# Encryption
ENCRYPTION_SECRET=your-encryption-secret-min-32-characters

# Security
SECURITY_LEVEL=medium
BLOCK_SUSPICIOUS_IP=false
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=30
SESSION_TIMEOUT=30

# Logging
LOG_LEVEL=info
LOG_RETENTION_DAYS=30

# Queue
QUEUE_REDIS_URL=redis://localhost:6379

# Backup
BACKUP_ENABLED=false
BACKUP_PATH=./backups
BACKUP_CRON=0 2 * * *

# Monitoring
MONITORING_INTERVAL=60
DATA_RETENTION_DAYS=90
