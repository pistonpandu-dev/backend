// ... previous schema ...

model Device {
  id                String   @id @default(uuid())
  deviceId          String   @unique
  deviceName        String
  brand             String?
  model             String?
  androidVersion    String?
  sdkVersion        String?
  serialNumber      String?
  screenResolution  String?
  batteryHealth     Int?
  totalStorage      BigInt?
  freeStorage       BigInt?
  ramTotal          BigInt?
  ramFree           BigInt?
  cpuInfo           String?
  networkInfo       String?
  status            DeviceStatus @default(offline)
  lastSeen          DateTime?    @default(now())
  fcmToken          String?
  
  // Security fields
  trustScore        Int?         @default(100)
  verificationLevel String?      @default("basic") // basic, advanced, verified
  securityFlags     Json?        // Store security-related flags
  lastVerification  DateTime?
  verificationAttempts Int?      @default(0)
  isCompromised     Boolean      @default(false)
  compromisedAt     DateTime?
  deletedAt         DateTime?    // Soft delete
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  enrollments       Enrollment[]
  monitoring        DeviceMonitoring[]
  locations         Location[]
  geofences         Geofence[]
  applications      Application[]
  files             File[]
  notifications     Notification[]
  securityAlerts    SecurityAlert[]
  groupMembers      DeviceGroupMember[]
  tagMembers        DeviceTagMember[]
  remoteSessions    RemoteSession[]
  screenSessions    ScreenSession[]

  @@map("devices")
}

model Admin {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(operator)
  avatar      String?
  isActive    Boolean  @default(true)
  lastLogin   DateTime?
  
  // Security fields
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  lastPasswordChange DateTime?
  passwordExpiry    DateTime?
  loginAttempts     Int     @default(0)
  lockedUntil       DateTime?
  securityQuestions Json?   // Store security questions
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    AdminSession[]
  auditLogs   AuditLog[]
  devices     Device[]
  files       File[]
  notifications Notification[]
  remoteSessions RemoteSession[]
  screenSessions ScreenSession[]

  @@map("admins")
}

model SecurityAlert {
  id          String   @id @default(uuid())
  deviceId    String?
  device      Device?  @relation(fields: [deviceId], references: [id])
  adminId     String?
  admin       Admin?   @relation(fields: [adminId], references: [id])
  level       AlertLevel @default(medium)
  title       String
  description String
  source      String?  // monitoring, security, system
  
  // Additional fields
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?
  actionTaken String?
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("security_alerts")
}

model Blacklist {
  id          String   @id @default(uuid())
  type        String   // ip, device, email, domain
  value       String
  reason      String?
  expiresAt   DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type, value])
  @@map("blacklists")
}

model Whitelist {
  id          String   @id @default(uuid())
  type        String   // ip, device, email, domain
  value       String
  reason      String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type, value])
  @@map("whitelists")
}
